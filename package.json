{
  "name": "pennyllm",
  "version": "0.0.0",
  "description": "Intelligent LLM API key rotation and quota management for free-tier optimization",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./storage": {
      "types": "./dist/storage/index.d.ts",
      "import": "./dist/storage/index.mjs",
      "require": "./dist/storage/index.cjs"
    },
    "./catalog": {
      "types": "./dist/catalog/index.d.ts",
      "import": "./dist/catalog/index.mjs",
      "require": "./dist/catalog/index.cjs"
    },
    "./selection": {
      "types": "./dist/selection/index.d.ts",
      "import": "./dist/selection/index.mjs",
      "require": "./dist/selection/index.cjs"
    },
    "./policy": {
      "types": "./dist/policy/index.d.ts",
      "import": "./dist/policy/index.mjs",
      "require": "./dist/policy/index.cjs"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.mjs",
      "require": "./dist/types/index.cjs"
    },
    "./errors": {
      "types": "./dist/errors/index.d.ts",
      "import": "./dist/errors/index.mjs",
      "require": "./dist/errors/index.cjs"
    },
    "./constants": {
      "types": "./dist/constants/index.d.ts",
      "import": "./dist/constants/index.mjs",
      "require": "./dist/constants/index.cjs"
    },
    "./wrapper": {
      "types": "./dist/wrapper/index.d.ts",
      "import": "./dist/wrapper/index.mjs",
      "require": "./dist/wrapper/index.cjs"
    },
    "./sqlite": {
      "types": "./dist/sqlite/index.d.ts",
      "import": "./dist/sqlite/index.mjs",
      "require": "./dist/sqlite/index.cjs"
    },
    "./redis": {
      "types": "./dist/redis/index.d.ts",
      "import": "./dist/redis/index.mjs",
      "require": "./dist/redis/index.cjs"
    },
    "./chain": {
      "types": "./dist/chain/index.d.ts",
      "import": "./dist/chain/index.mjs",
      "require": "./dist/chain/index.cjs"
    },
    "./providers": {
      "types": "./dist/providers/index.d.ts",
      "import": "./dist/providers/index.mjs",
      "require": "./dist/providers/index.cjs"
    }
  },
  "files": [
    "dist",
    "data",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "prepare": "husky",
    "catalog:update": "tsx scripts/generate-catalog.ts",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "npm run build && changeset publish",
    "update-catalog": "tsx scripts/generate-catalog.ts"
  },
  "peerDependencies": {
    "@ai-sdk/cerebras": "^2.0.0",
    "@ai-sdk/google": "^3.0.0",
    "@ai-sdk/groq": "^3.0.0",
    "@ai-sdk/mistral": "^3.0.0",
    "@ai-sdk/openai-compatible": "^2.0.0",
    "ai": "^6.0.0",
    "better-sqlite3": "^11.0.0 || ^12.0.0",
    "ioredis": "^5.0.0",
    "js-yaml": "^4.0.0",
    "sambanova-ai-provider": "^1.0.0"
  },
  "peerDependenciesMeta": {
    "@ai-sdk/cerebras": {
      "optional": true
    },
    "@ai-sdk/google": {
      "optional": true
    },
    "@ai-sdk/groq": {
      "optional": true
    },
    "@ai-sdk/mistral": {
      "optional": true
    },
    "@ai-sdk/openai-compatible": {
      "optional": true
    },
    "js-yaml": {
      "optional": true
    },
    "better-sqlite3": {
      "optional": true
    },
    "ioredis": {
      "optional": true
    },
    "sambanova-ai-provider": {
      "optional": true
    }
  },
  "dependencies": {
    "@ai-sdk/provider": "^3.0.0",
    "debug": "^4.3.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@ai-sdk/cerebras": "^2.0.39",
    "@ai-sdk/google": "^3.0.43",
    "@ai-sdk/groq": "^3.0.29",
    "@ai-sdk/mistral": "^3.0.24",
    "@ai-sdk/openai-compatible": "^2.0.35",
    "@changesets/cli": "^2.27.10",
    "@commitlint/cli": "^19.6.2",
    "@commitlint/config-conventional": "^19.6.0",
    "@eslint/js": "^9.17.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/debug": "^4.1.12",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.5",
    "@vitest/coverage-v8": "^2.1.8",
    "ai": "^6.0.0",
    "better-sqlite3": "^12.8.0",
    "eslint": "^9.17.0",
    "husky": "^9.1.7",
    "ioredis": "^5.10.0",
    "js-yaml": "^4.1.0",
    "lint-staged": "^15.2.11",
    "prettier": "^3.4.2",
    "sambanova-ai-provider": "^1.2.2",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2",
    "vitest": "^2.1.8"
  },
  "license": "MIT",
  "keywords": [
    "llm",
    "router",
    "api-key",
    "quota",
    "rate-limit",
    "free-tier",
    "ai-sdk"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/muhammaduzair/pennyllm.git"
  },
  "bugs": {
    "url": "https://github.com/muhammaduzair/pennyllm/issues"
  },
  "homepage": "https://github.com/muhammaduzair/pennyllm#readme"
}
